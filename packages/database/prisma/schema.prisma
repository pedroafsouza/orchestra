generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  accounts       Account[]
  sessions       Session[]
  ownedProjects  Project[]       @relation("ProjectOwner")
  memberships    ProjectMember[]

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  guid      String   @unique @default(cuid())
  ownerId   String   @db.ObjectId
  diagram   Json?    // Draft diagram state (nodes, edges, positions)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User              @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  flows       Flow[]
  datasources Datasource[]
  assets      Asset[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  projectId String   @db.ObjectId
  role      String   @default("editor") // "owner" | "editor" | "viewer"
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

// ─── Flows ───────────────────────────────────────────────────────────────────

model Flow {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  version   Int      @default(1)
  data      Json     // The full OrchestraFlow JSON (includes screen components per node)
  published Boolean  @default(false)
  projectId String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name, version])
  @@map("flows")
}

// ─── Datasources ─────────────────────────────────────────────────────────────

model Datasource {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  projectId       String    @db.ObjectId
  fields          Json      // Array of { key, label, type: "text"|"number"|"image_url"|"boolean" }
  sourceType      String    @default("manual") // "manual" | "rest"
  sourceConfig    Json?     // REST config (url, method, headers, auth, etc.)
  lastFetchAt     DateTime?
  lastFetchStatus String?   // "success" | "error" | "pending"
  lastFetchError  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entries DatasourceEntry[]

  @@unique([projectId, name])
  @@map("datasources")
}

model DatasourceEntry {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  datasourceId String   @db.ObjectId
  data         Json     // Key-value pairs matching the datasource fields
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  datasource Datasource @relation(fields: [datasourceId], references: [id], onDelete: Cascade)

  @@map("datasource_entries")
}

// ─── Assets ─────────────────────────────────────────────────────────────────

model Asset {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @db.ObjectId
  filename    String
  storagePath String
  mimeType    String
  category    String   @default("image")
  size        Int
  width       Int?
  height      Int?
  thumbPath   String?
  alt         String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, category])
  @@map("assets")
}

// ─── Analytics ──────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @db.ObjectId
  sessionId   String
  eventType   String   // page_view, button_click, form_submit, navigation, datasource_action, checkbox_toggle, switch_toggle
  nodeId      String?
  componentId String?
  metadata    Json?
  deviceInfo  Json?
  timestamp   DateTime @default(now())

  @@index([projectId, timestamp])
  @@index([projectId, eventType])
  @@map("analytics_events")
}
